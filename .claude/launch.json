{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "storybook",
      "runtimeExecutable": "/opt/homebrew/bin/npx",
      "env": { "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin" },
      "runtimeArgs": ["storybook", "dev", "-p", "6006"],
      "port": 6006
    },
    {
      "name": "next-dev",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "env": { "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin" },
      "runtimeArgs": ["node_modules/.bin/next", "dev"],
      "port": 3000
    }
  ]
}
